@startuml

class Member {
  +id: String
  +nama: String
  -saldo: Int
  +topUp(jumlah: Int)
  +potongSaldo(jumlah: Int): Boolean
}

class Lapangan {
  +nama: String
  +hargaPerJam: Int
  -jadwalTerbooking: List<String>
  +cekKetersediaan(jam: String): Boolean
  +tambahJadwal(jam: String)
  +tampilkanJadwal()
}

class Resepsionis {
  +nama: String
  +prosesBooking(member: Member, lapangan: Lapangan, jam: String)
}

Resepsionis --> Member
Resepsionis --> Lapangan

@enduml
